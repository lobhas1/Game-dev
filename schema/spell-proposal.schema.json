{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spellcraft/schema/spell-proposal.schema.json",
  "title": "Spell — proposal stage",
  "description": "The oracle-facing descriptor: qualitative bands and budget shares only. No raw resolved numbers (no amplify:2.5, no tickInterval:0.25). Every magnitude field is a band enum; share/tier/counts are the only numerics. The strict deserializer (SpellJson) is the executable enforcement of this contract; unknown verbs/statuses/fields are hard failures.",
  "type": "object",
  "required": ["id", "tier", "clauses"],
  "additionalProperties": false,
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "tier": { "type": "integer", "minimum": 1 },
    "cast": { "$ref": "#/$defs/cast" },
    "delivery": { "$ref": "#/$defs/delivery" },
    "clauses": { "type": "array", "items": { "$ref": "#/$defs/clause" } }
  },
  "$defs": {
    "element": { "enum": ["fire", "water", "earth", "air", "light", "shadow", "nature", "arcane"] },
    "status": {
      "enum": ["burn", "poison", "bleed", "chill", "freeze", "shock", "stun", "root", "slow", "silence",
               "disarm", "blind", "fear", "weaken", "vulnerable", "haste", "regen", "stealth", "unstoppable", "invulnerable"]
    },
    "verb": {
      "enum": ["damage", "heal", "shield", "applyStatus", "dispel", "modifyStat", "displace", "spawnZone",
               "summon", "mark", "detonate", "drainResource", "createBarrier", "reveal", "taunt", "reflect",
               "modifyAbility", "tether", "transform", "lifeLink", "absorb", "charm", "banish", "commandMinions",
               "resurrect", "terraform", "timeDilate", "possess", "castSpell"]
    },
    "templateKind": { "enum": ["onHit", "onKill", "onCrit", "ifStatus", "delayed", "repeating", "onExpire", "hpThreshold"] },

    "castTimeBand": { "enum": ["instant", "quick", "normal", "long"] },
    "durationBand": { "enum": ["instant", "short", "medium", "long"] },
    "cooldownBand": { "enum": ["short", "medium", "long"] },
    "sizeBand": { "enum": ["tiny", "small", "medium", "large"] },
    "speedBand": { "enum": ["slow", "fast"] },
    "intervalBand": { "enum": ["fast", "medium", "slow"] },
    "costBand": { "enum": ["trivial", "low", "moderate", "high"] },
    "multiplierBand": { "enum": ["minor", "major", "extreme"] },
    "share": { "type": "number", "minimum": 0, "maximum": 4 },

    "cost": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "resource": { "enum": ["mana", "stamina", "health"] },
        "amount": { "$ref": "#/$defs/costBand" }
      }
    },
    "cast": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode"],
      "properties": {
        "mode": { "enum": ["instant", "cast", "channel", "charge", "passive", "reactive", "aura"] },
        "castTime": { "$ref": "#/$defs/castTimeBand" },
        "cooldown": { "$ref": "#/$defs/cooldownBand" },
        "cost": { "$ref": "#/$defs/cost" },
        "interruptible": { "type": "boolean" },
        "moveWhileCasting": { "type": "boolean" }
      }
    },
    "delivery": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": { "enum": ["self", "melee", "targetUnit", "projectile", "groundAoE", "nova", "beam", "chain", "atPoint"] },
        "shape": { "enum": ["circle", "cone", "line", "ring"] },
        "size": { "$ref": "#/$defs/sizeBand" },
        "range": { "$ref": "#/$defs/sizeBand" },
        "speed": { "$ref": "#/$defs/speedBand" },
        "telegraph": { "type": "boolean" }
      }
    },
    "template": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind"],
      "properties": {
        "kind": { "$ref": "#/$defs/templateKind" },
        "status": { "$ref": "#/$defs/status" },
        "consume": { "type": "boolean" },
        "amplify": { "$ref": "#/$defs/multiplierBand" },
        "delay": { "$ref": "#/$defs/durationBand" },
        "times": { "type": "integer", "minimum": 1 },
        "interval": { "$ref": "#/$defs/intervalBand" },
        "pct": { "type": "number", "minimum": 0, "maximum": 100 },
        "side": { "enum": ["above", "below"] },
        "also": { "type": "array", "items": { "$ref": "#/$defs/clause" } },
        "clauses": { "type": "array", "items": { "$ref": "#/$defs/clause" } }
      }
    },
    "clause": {
      "type": "object",
      "additionalProperties": false,
      "required": ["verb"],
      "properties": {
        "verb": { "$ref": "#/$defs/verb" },
        "template": { "$ref": "#/$defs/template" },
        "element": { "$ref": "#/$defs/element" },
        "status": { "$ref": "#/$defs/status" },
        "share": { "$ref": "#/$defs/share" },
        "duration": { "$ref": "#/$defs/durationBand" },
        "size": { "$ref": "#/$defs/sizeBand" },
        "distance": { "$ref": "#/$defs/sizeBand" },
        "speed": { "$ref": "#/$defs/speedBand" },
        "tickInterval": { "$ref": "#/$defs/intervalBand" },
        "mode": { "enum": ["teleport", "dash", "push", "pull", "launch", "swap"] },
        "subject": { "enum": ["caster", "target"] },
        "to": { "enum": ["point", "impact", "caster", "behindTarget"] },
        "shape": { "enum": ["circle", "cone", "line", "ring"] },
        "affects": { "enum": ["enemies", "allies", "all"] },
        "category": { "enum": ["buff", "debuff", "dot", "all"] },
        "order": { "enum": ["newest", "oldest", "strongest"] },
        "count": { "type": "integer", "minimum": 1 },
        "stat": { "type": "string" },
        "direction": { "enum": ["buff", "debuff"] },
        "canCrit": { "type": "boolean" },
        "canOverhealToShield": { "type": "boolean" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "leechPct": { "type": "number", "minimum": 0, "maximum": 100 },
        "stacks": { "type": "integer", "minimum": 1 },
        "tickClauses": { "type": "array", "items": { "$ref": "#/$defs/clause" } },
        "onEnterClauses": { "type": "array", "items": { "$ref": "#/$defs/clause" } },
        "onExitClauses": { "type": "array", "items": { "$ref": "#/$defs/clause" } }
      }
    }
  }
}
